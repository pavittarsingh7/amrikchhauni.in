# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/acdm?schema=public"

# Session secret (generate a random 32+ char string for production)
AUTH_SECRET="change-me-to-a-long-random-secret-in-production"

# ACDM application port
PORT=3000

# Seed users (used by: npm run seed)
SEED_USER_SUPER_ADMIN_USERNAME=acdmsuperadmin
SEED_USER_SUPER_ADMIN_PASSWORD=change-me
SEED_USER_ADMINISTRATOR_USERNAME=acdmadministrator
SEED_USER_ADMINISTRATOR_PASSWORD=change-me
SEED_USER_VIEWER_USERNAME=acdmviewer
SEED_USER_VIEWER_PASSWORD=change-me
